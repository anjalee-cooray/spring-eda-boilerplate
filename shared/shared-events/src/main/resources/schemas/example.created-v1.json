{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "example.created-v1",
  "title": "ExampleCreated v1",
  "description": "Payload schema for the example.created event, schema version 1.",
  "type": "object",
  "required": ["id", "name", "tenantId", "status"],
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier of the created entity."
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Display name of the entity."
    },
    "tenantId": {
      "type": "string",
      "minLength": 1,
      "description": "Tenant that owns this entity."
    },
    "status": {
      "type": "string",
      "enum": ["ACTIVE", "INACTIVE"],
      "description": "Initial lifecycle status."
    }
  },
  "additionalProperties": true
}
