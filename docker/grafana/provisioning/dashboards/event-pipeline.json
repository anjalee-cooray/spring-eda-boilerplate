{
  "title": "Event Pipeline",
  "uid": "eda-event-pipeline",
  "schemaVersion": 38,
  "refresh": "10s",
  "description": "Outbox relay throughput, DLQ depth, and replay job status",
  "panels": [
    {
      "id": 1,
      "title": "Outbox — Pending Records",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 8 },
      "targets": [
        {
          "expr": "outbox_records_pending",
          "legendFormat": "pending"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "thresholds": { "steps": [
          { "color": "green", "value": 0 },
          { "color": "yellow", "value": 1000 },
          { "color": "red", "value": 5000 }
        ]}}
      }
    },
    {
      "id": 2,
      "title": "Outbox — In-Flight Records",
      "type": "timeseries",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 8 },
      "targets": [
        {
          "expr": "outbox_records_in_flight",
          "legendFormat": "in-flight"
        }
      ]
    },
    {
      "id": 3,
      "title": "Outbox — Failed Records (requires operator action)",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 8 },
      "targets": [
        {
          "expr": "outbox_records_failed",
          "legendFormat": "failed"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": 0 },
          { "color": "red", "value": 1 }
        ]}}
      }
    },
    {
      "id": 4,
      "title": "Outbox Relay — Publish Rate (events/s)",
      "type": "timeseries",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 8 },
      "targets": [
        {
          "expr": "rate(outbox_relay_published_total[1m])",
          "legendFormat": "published/s"
        }
      ]
    },
    {
      "id": 5,
      "title": "DLQ Depth — Kafka (events.dlq.received rate)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(events_dlq_received_total[5m])",
          "legendFormat": "{{topic}} dlq rate"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "thresholds": { "steps": [
          { "color": "green", "value": 0 },
          { "color": "red", "value": 0.01 }
        ]}}
      }
    },
    {
      "id": 6,
      "title": "DLQ Depth — SQS (sqs.consumer.lag type=dlq)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sqs_consumer_lag{type=\"dlq\"}",
          "legendFormat": "{{queue}} dlq depth"
        }
      ],
      "fieldConfig": {
        "defaults": { "thresholds": { "steps": [
          { "color": "green", "value": 0 },
          { "color": "red", "value": 1 }
        ]}}
      }
    },
    {
      "id": 7,
      "title": "Relay Not Publishing (pending > 0, publish rate = 0)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 16, "w": 8, "h": 6 },
      "description": "Should be 0. Non-zero means relay is stuck. Alert: OutboxRelayNotPublishing",
      "targets": [
        {
          "expr": "clamp_min(outbox_records_pending > 0, 0) AND rate(outbox_relay_published_total[5m]) == 0",
          "legendFormat": "relay stuck"
        }
      ]
    },
    {
      "id": 8,
      "title": "Replay Job Status",
      "type": "table",
      "gridPos": { "x": 8, "y": 16, "w": 16, "h": 6 },
      "description": "Active replay jobs — polled from /replay/jobs actuator endpoint",
      "targets": [
        {
          "expr": "replay_jobs_active",
          "legendFormat": "active"
        },
        {
          "expr": "replay_jobs_completed",
          "legendFormat": "completed"
        },
        {
          "expr": "replay_jobs_failed",
          "legendFormat": "failed"
        }
      ]
    }
  ]
}
