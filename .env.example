# Copy this file to .env and fill in values for local development
# .env is gitignored — never commit real secrets

DB_URL=jdbc:postgresql://localhost:5432/edadb
DB_USERNAME=postgres
DB_PASSWORD=postgres

# Local dev: mock-oauth2-server running in Docker
# Staging/production: your real Okta issuer URI
# Format: https://<your-okta-domain>/oauth2/<auth-server-id>
OIDC_ISSUER_URI=http://localhost:8090/okta

KAFKA_BOOTSTRAP_SERVERS=localhost:9092
EVENTS_BROKER=kafka

REDIS_HOST=localhost
REDIS_PORT=6379

RELAY_POLL_INTERVAL_MS=1000
RELAY_BATCH_SIZE=50
